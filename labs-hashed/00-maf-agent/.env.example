# ─── Azure AI Agents (Azure Foundry) ─────────────────────────────────────────
# Find in: ai.azure.com → Your Project → Overview → Endpoints
# Format: https://<resource>.services.ai.azure.com/api/projects/<project>
AZURE_AI_AGENTS_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project

# Azure AI Agents API Key
# Find in: ai.azure.com → Your Project → Overview → Keys
# Used for auth in Container Apps (instead of DefaultAzureCredential)
AZURE_AI_AGENTS_KEY=your_api_key_here

# Azure AI model deployment name
# Check yours: az cognitiveservices account deployment list --name <resource> --resource-group <rg>
AZURE_OPENAI_DEPLOYMENT_NAME=DeepSeek-V3-0324

# ─── Hashed SDK ───────────────────────────────────────────────────────────────
# Get from: your Hashed account dashboard
HASHED_BACKEND_URL=https://iamandagent-production.up.railway.app
HASHED_API_KEY=hashed_your_api_key_here
HASHED_IDENTITY_PASSWORD=your_strong_password_here

# ─── Hashed PEM (Agent Identity — Production Only) ───────────────────────────
# The agent's cryptographic identity. In containers the filesystem is ephemeral,
# so we store the PEM as a base64-encoded Azure Secret to ensure the same
# identity is used across restarts (no more duplicate agents in Hashed).
#
# Setup (one-time):
#   PEM_B64=$(base64 -i secrets/maf_research_agent.pem)
#   az containerapp secret set --name maf-research-agent \
#       --resource-group <your-resource-group> \
#       --secrets "hashed-pem-b64=$PEM_B64"
#
# The deploy.sh injects it automatically:
#   HASHED_PEM_B64=secretref:hashed-pem-b64
#
# NOT needed locally — agent_core.py falls back to ./secrets/maf_research_agent.pem
# HASHED_PEM_B64=  # leave empty for local dev

# ─── Azure Deployment Config (optional — used by deploy.sh) ──────────────────
# Your Azure Resource Group for Container Apps deployment
AZURE_RESOURCE_GROUP=my-resource-group
# Azure region (e.g. eastus, westeurope, swedencentral)
AZURE_LOCATION=swedencentral
# Container App name (must be unique in your subscription)
AZURE_CONTAINER_APP_NAME=maf-research-agent

# ─── Setup Steps ─────────────────────────────────────────────────────────────
# 1. Copy this file:      cp .env.example .env
# 2. Fill in your values
# 3. Register policies:   hashed policy add search_web --allow --agent "MAF Research Agent"
#                         hashed policy add send_email --deny --agent "MAF Research Agent"
#                         hashed policy push
# 4. Run CLI:             python agent.py --demo
# 5. Run UI:              streamlit run app.py
# 6. Deploy to Azure:     bash deploy/deploy.sh
